{
    "name": "psc-acme/transformer-auth",
    "description": "Package transformer-auth for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\TransformerAuth\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/symfony": "^6.3",
        "symfony/cache": "^7.0",
        "symfony/http-kernel": "^6.2",
        "brick/date-time": "^0.7.1"
    },
    "require-dev": {
        "rector/rector": "^1.0",
        "phpunit/phpunit": "^10.5",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}